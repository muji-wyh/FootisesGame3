# Godot 4 .gitignore

.idea/

# Godot-specific import cache and generated files
.godot/
/android/
/build/
/export/

# Exported web build output (regenerate via Godot export)
/web-build/

# Imported translations and temp files
*.translation
*.tmp

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# Local tooling (Godot editor binary, export templates) live outside the repo,
# but ignore them here too in case they are copied in.
/.tools/
godot*.exe
*.tpz

# Licensed Unity assets (Fighters Pack, Kubold Fighting Animset Pro) — kept local,
# NEVER committed. The model-backed rig falls back to the procedural blockout when
# these are absent, so a clean clone still runs. Per-character under characters/<id>/assets/
# (each character's README.md IS tracked).
characters/**/assets/**/*.fbx
characters/**/assets/**/*.FBX
characters/**/assets/**/*.tga
characters/**/assets/**/*.png
characters/**/assets/**/*.tscn
characters/**/assets/**/*.fbx.import
characters/**/assets/**/*.FBX.import
characters/**/assets/**/*.tga.import
characters/**/assets/**/*.png.import
characters/**/assets/**/*.tscn.import
_probe/


# stray dev probe files
_probe_inst.gd*
tools/probe2.gd*
