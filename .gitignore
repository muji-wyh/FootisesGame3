# Godot 4 .gitignore

# Godot-specific import cache and generated files
.godot/
/android/
/build/
/export/

# Exported web build output (regenerate via Godot export)
/web-build/

# Imported translations and temp files
*.translation
*.tmp

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# Local tooling (Godot editor binary, export templates) live outside the repo,
# but ignore them here too in case they are copied in.
/.tools/
godot*.exe
*.tpz

# Licensed Unity assets (Fighters Pack, Kubold Fighting Animset Pro) — kept local,
# NEVER committed. The model-backed rig falls back to the procedural blockout when
# these are absent, so a clean clone still runs.
assets/models/**/*.fbx
assets/models/**/*.FBX
assets/models/**/*.tga
assets/models/**/*.fbx.import
assets/models/**/*.FBX.import
assets/models/**/*.tga.import
_probe/

